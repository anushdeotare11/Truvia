# ------------------------------------------------------------------------------
# Truvia frontend configuration
# Copy this file to `.env` (or `.env.local`) and fill in the values you need.
# Next.js loads env files from the frontend project root at build/start time.
#
# NOTE: Only NEXT_PUBLIC_* variables are exposed to the browser bundle.
# NODE_ENV is set automatically by Next.js (dev/build/start) — do not set it here.
# ------------------------------------------------------------------------------

# --- Backend API ---
# Base URL the browser uses to reach the backend API (used in src/lib/api.ts).
# Leave blank to use the built-in default: http://127.0.0.1:8000/api/v1
# In local dev, next.config.mjs also proxies /api/* to the backend, so the
# default usually works without setting this. Set it when the backend runs on a
# different host/port (e.g. a deployed environment).
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1
