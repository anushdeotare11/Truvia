# ------------------------------------------------------------------------------
# Truvia frontend configuration
# Copy this file to `.env` (or `.env.local`) and fill in the values you need.
# Next.js loads env files from the frontend project root at build/start time.
#
# NOTE: Only NEXT_PUBLIC_* variables are exposed to the browser bundle.
# NODE_ENV is set automatically by Next.js (dev/build/start) — do not set it here.
# ------------------------------------------------------------------------------

# --- Backend API ---
# Base URL (ORIGIN ONLY) the browser uses to reach the backend API (used in src/lib/api.ts).
# Do NOT include /api or /api/v1 — the client appends /api/v1 automatically.
# Local dev: leave blank to use the built-in proxy (next.config.mjs proxies /api/* to the backend).
# Production (Vercel): set this to your Render backend origin, e.g.
#   NEXT_PUBLIC_API_URL=https://truvia-backend.onrender.com
NEXT_PUBLIC_API_URL=
