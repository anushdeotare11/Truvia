# ====================================================================
# Truvia Backend Environment Template
# ⚠️ DO NOT INCLUDE REAL SECRETS IN THIS FILE
# ====================================================================

APP_NAME="Truvia Digital Public Safety Platform"
DEBUG=True
PORT=8000
HOST="127.0.0.1"

# Database Configuration (Neon PostgreSQL)
DATABASE_URL="postgresql+asyncpg://your_db_user:your_db_password@your_host/neondb?sslmode=require"

# AI Engine Credentials (Google Gemini)
GOOGLE_API_KEY="your_google_gemini_api_key_here"

# Cloud Storage Credentials (Cloudinary)
CLOUDINARY_URL="cloudinary://your_api_key:your_api_secret@your_cloud_name"
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Graph Database Configuration (Neo4j)
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="your_neo4j_password_here"

# Security Configuration
JWT_SECRET="your_jwt_secret_key_change_in_production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ====================================================================
# Railway Deployment Notes
# ====================================================================
# These notes cover how the above keys behave when deployed on Railway
# (the same guidance applies to Render/Heroku-style platforms).
#
# PORT
#   Injected automatically by Railway at runtime. Do NOT hardcode it here or
#   in the start command — the Procfile reads ${PORT} for you.
#
# DATABASE_URL
#   - Leave UNSET for the simplest setup: the app falls back to a built-in
#     ephemeral SQLite database and auto-seeds the demo login accounts on each
#     deploy (data does not persist across redeploys).
#   - OR attach a Railway PostgreSQL plugin and set DATABASE_URL. Any provider
#     form is accepted (postgres://..., postgresql://..., or the explicit
#     postgresql+asyncpg://...) — it is auto-normalized to the async driver and
#     any libpq `sslmode=` param is stripped for asyncpg compatibility.
#   - If you use Postgres, run `alembic upgrade head` once to create the tables.
#
# GOOGLE_API_KEY
#   Set this to enable full AI capabilities (threat scoring, OCR, speech-to-text).
#   Without it, scoring runs in a degraded local rule-engine mode.
#
# Optional integrations (all degrade gracefully if absent):
#   NEO4J_URI / NEO4J_USER / NEO4J_PASSWORD  — threat graph features
#   REDIS_URL                                — background queue features
