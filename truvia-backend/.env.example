# ------------------------------------------------------------------------------
# Truvia backend configuration
# Copy this file to `.env` and fill in the values you have.
#
# The platform runs WITHOUT any of these keys (degraded/local mode) and will never
# fabricate analysis results. Keys unlock real cloud AI capabilities:
#   - GOOGLE_API_KEY  -> Gemini vision OCR + LLM threat reasoning + RAG chat answers
#   - OPENAI_API_KEY  -> Whisper audio speech-to-text (ASR)
# Check GET /api/v1/config-status (or the startup log) to see what is active.
#
# All variables are loaded by app/config.py (pydantic BaseSettings, env_file=".env").
# Every value below is a non-secret placeholder/default; real secrets stay blank.
# ------------------------------------------------------------------------------

# --- General app config ---
# Application display name.
APP_NAME=Truvia
# Runtime environment: dev, staging, or production.
ENV=dev
# Enable verbose/debug behaviour (true/false). Set to false in production.
DEBUG=true
# Port the FastAPI/uvicorn server binds to.
PORT=8000
# Host interface the server binds to (0.0.0.0 = all interfaces).
HOST=0.0.0.0

# --- AI / LLM providers (recommended for full functionality) ---
# Google Gemini: vision OCR + threat reasoning + RAG chat. Free tier at
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
# OpenAI: enables audio speech-to-text (Whisper). https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Anthropic (optional; not required — Gemini is the primary provider).
ANTHROPIC_API_KEY=

# --- Database ---
# Postgres connection string. Defaults to a local SQLite file (truvia.db) when
# Postgres is unreachable. Local docker-compose value shown below.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/truvia

# --- Redis (optional; background tasks run in-process without it) ---
REDIS_URL=redis://localhost:6379/0

# --- Neo4j (optional; graph correlation degrades to SQLite when offline) ---
# Bolt URI, username and password for the graph database (see docker-compose.yml).
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# --- Auth (JWT) ---
# Secret used to sign JWTs. MUST be changed to a strong random value in production.
JWT_SECRET_KEY=change-me-in-production
# Signing algorithm for JWTs.
JWT_ALGORITHM=HS256
# Access token lifetime in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=15
# Refresh token lifetime in days.
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Storage ---
# Storage backend: "local" or "s3".
STORAGE_TYPE=local
# Bucket name used when STORAGE_TYPE=s3.
STORAGE_BUCKET_NAME=truvia-evidence
# Directory used when STORAGE_TYPE=local.
LOCAL_STORAGE_DIR=./storage/evidence

# --- Cloudinary Storage Config (Free tier at https://cloudinary.com) ---
# Set STORAGE_TYPE=cloudinary to enable
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=

# --- OCR / ASR confidence thresholds (below this => low-confidence/degraded banner) ---
OCR_LOW_CONFIDENCE_THRESHOLD=0.60
ASR_LOW_CONFIDENCE_THRESHOLD=0.60
